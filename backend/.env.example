# MongoDB connection string (get from MongoDB Atlas → Connect → Drivers)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/?appName=Cluster0

# Groq API key (get from https://console.groq.com)
GROQ_API_KEY=gsk_...

# Server port (optional, defaults to 5000)
PORT=5000

# ── Email notification (optional) ────────────────────────────────────────────
# If set, an email is sent to NOTIFY_EMAIL whenever a new lead is captured.
# Example below uses Gmail — enable "App Passwords" in your Google account.
# For other providers, change SMTP_HOST and SMTP_PORT accordingly.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
NOTIFY_EMAIL=leads@yourcompany.com
